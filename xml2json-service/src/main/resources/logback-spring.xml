<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProperty scope="context" name="API_LOG_FILE" source="app.logging.audit-file" defaultValue="logs/default-audit.log"/>
    <springProperty scope="context" name="API_AUDIT_LEVEL" source="app.logging.audit-level" defaultValue="INFO"/>

    <appender name="API_AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${API_LOG_FILE}</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${API_LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="API_INTERACTION" level="${API_AUDIT_LEVEL}" additivity="false">
        <appender-ref ref="API_AUDIT_FILE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>