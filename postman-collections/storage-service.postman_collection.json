              "body": "{\n  \"type\": \"about:blank\",\n  \"title\": \"Invalid Request\",\n  \"status\": 400,\n  \"detail\": \"Content length must be positive: 0\",\n  \"timestamp\": \"2026-06-29T00:00:00Z\"\n}"
