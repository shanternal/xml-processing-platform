{
  "info": {
    "name": "xml2json-service",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Коллекция для Сервиса 2 — конвертация XML в JSON.\n\nБазовый URL задаётся через переменную коллекции `baseUrl`.\nПо умолчанию: http://localhost:8081",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "POST api/v1/xml2json",
      "item": [
        {
          "name": "200 — Простой XML",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<user>\n  <id>1</id>\n  <name>Ivan Petrov</name>\n  <email>ivan@example.com</email>\n</user>",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/xml2json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "xml2json"]
            },
            "description": "Базовый сценарий: простая XML-структура с несколькими полями. Ожидаем 200 OK с JSON в теле ответа."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/xml" },
                  { "key": "Accept", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "<user>\n  <id>1</id>\n  <name>Ivan Petrov</name>\n  <email>ivan@example.com</email>\n</user>"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/xml2json",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "xml2json"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\"user\":{\"id\":1,\"name\":\"Ivan Petrov\",\"email\":\"ivan@example.com\"}}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('object');",
                  "});",
                  "",
                  "pm.test(\"Content-Type is application/json\", function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "200 — Вложенный XML",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<order>\n  <id>42</id>\n  <status>NEW</status>\n  <customer>\n    <id>7</id>\n    <name>Maria Sidorova</name>\n  </customer>\n  <items>\n    <item>\n      <sku>ITEM-001</sku>\n      <qty>2</qty>\n      <price>199.99</price>\n    </item>\n    <item>\n      <sku>ITEM-002</sku>\n      <qty>1</qty>\n      <price>49.50</price>\n    </item>\n  </items>\n</order>",
              "options": {
                "raw": { "language": "xml" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/xml2json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "xml2json"]
            },
            "description": "Вложенная структура с массивом элементов. Проверяет корректную конвертацию иерархии и повторяющихся тегов."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('order');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "200 — XML с атрибутами",
          "request": {
