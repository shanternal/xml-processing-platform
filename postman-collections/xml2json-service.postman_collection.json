              }
            }
          ]
        },
        {
          "name": "400 — Невалидный XML",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "<user>\n  <name>Ivan\n  <email>ivan@example.com</email>\n</user>",
              "options": {
                "raw": { "language": "xml" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/xml2json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "xml2json"]
            },
            "description": "Незакрытый тег <name> — невалидный XML. Ожидаем 400 Bad Request с ProblemDetail в теле."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "originalRequest": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/xml" },
                  { "key": "Accept", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "<user>\n  <name>Ivan\n  <email>ivan@example.com</email>\n</user>"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/xml2json",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "xml2json"]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/problem+json" }
              ],
              "body": "{\n  \"type\": \"about:blank\",\n  \"title\": \"Invalid XML\",\n  \"status\": 400,\n  \"detail\": \"Invalid XML\",\n  \"timestamp\": \"2026-06-18T10:00:00Z\"\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Response contains ProblemDetail fields\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('title');",
                  "    pm.expect(body).to.have.property('status');",
                  "    pm.expect(body).to.have.property('detail');",
                  "    pm.expect(body).to.have.property('timestamp');",
                  "    pm.expect(body.status).to.eql(400);",
                  "    pm.expect(body.title).to.eql('Invalid XML');",
                  "});"
                ]
              }
            }
          ]
        },
