                  "    pm.response.to.be.json;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "200 — XML с одним тегом",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/xml" },
